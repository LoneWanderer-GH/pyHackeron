# Configuration Corelec BLE Daemon
# Copié vers /etc/corelec/config.env par install_raspi.sh
# Modifier puis : sudo systemctl restart corelec-daemon

# Adresse BLE du régulateur (obligatoire)
CORELEC_ADDRESS=B4:E3:F9:5A:0A:13

# Ports ZeroMQ
CORELEC_PUB_PORT=5555
CORELEC_CMD_PORT=5556

# Base de données SQLite
CORELEC_DB_PATH=/opt/corelec/pool.db

# Intervalle de polling BLE en secondes (défaut 5.0)
# Diminuer si les données semblent trop retardées ; augmenter pour réduire la charge.
CORELEC_POLL_INTERVAL=5.0

# Niveau de log : DEBUG | INFO | WARNING | ERROR
CORELEC_LOG_LEVEL=INFO
