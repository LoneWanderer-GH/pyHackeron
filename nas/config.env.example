# Configuration Corelec Web Server — NAS Synology
# Copié vers /etc/corelec/web.env par install_nas.sh
# Modifier puis : sudo systemctl restart corelec-web

# IP du Raspberry Pi exécutant ble_daemon.py (obligatoire)
CORELEC_HOST=192.168.0.16

# Ports ZeroMQ du daemon BLE
CORELEC_PUB_PORT=5555
CORELEC_CMD_PORT=5556

# Port HTTP du serveur web Corelec (accessible sur le LAN)
CORELEC_WEB_PORT=8080

# Niveau de log : DEBUG | INFO | WARNING | ERROR
CORELEC_LOG_LEVEL=INFO
